# ============================================
# TimSumV3 — Environment Variables
# ============================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าตามความต้องการ
#   cp .env.example .env
#
# ค่าที่มี ❗ = ต้องแก้ก่อนใช้งาน
# ค่าที่มี 🔒 = แนะนำให้แก้ (security)
# ค่าที่ไม่มี marker = ใช้ค่า default ได้

# ============================================
# AI Services (❗ ต้องแก้)
# ============================================

# Hugging Face Token for speaker diarization (pyannote)
# Get your token from: https://huggingface.co/settings/tokens
# ❗ ต้อง Accept License ที่ pyannote/speaker-diarization-3.1 ด้วย
HF_TOKEN=your_hf_token_here

# NTC AI Gateway API Configuration (GPT-4.1)
# ❗ ต้องขอ API Key จาก NTC หรือเปลี่ยนเป็น OpenAI API
NTC_API_KEY=your_ntc_api_key_here
NTC_API_URL=https://aigateway.ntictsolution.com/v1/chat/completions
NTC_MODEL=gpt-4.1

# ============================================
# Email (Optional — leave blank to disable)
# ============================================
SMTP_SERVER=
SMTP_PORT=25
EMAIL_USERNAME=
EMAIL_PASSWORD=
SENDER_EMAIL=

# ============================================
# Database & Authentication (🔒 แก้ password)
# ============================================
MONGO_USER=timsumadmin
MONGO_PASS=CHANGE_ME_strong_password

# ⚠️ ไม่ต้องแก้ MONGO_CONNECTION_STRING — docker-compose.yml จะ override
#   ให้ใช้ค่าจาก MONGO_USER + MONGO_PASS อัตโนมัติ
MONGO_CONNECTION_STRING=mongodb://timsumadmin:CHANGE_ME_strong_password@mongo:27017
MONGO_DB_NAME=timsumv3

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_command_above
JWT_EXPIRE_HOURS=8

# ============================================
# Redis (Celery Job Queue) (🔒 แก้ password)
# ============================================
REDIS_PASSWORD=CHANGE_ME_strong_password

# ⚠️ ไม่ต้องแก้ REDIS_URL — docker-compose.yml จะ override
#   ให้ใช้ค่าจาก REDIS_PASSWORD อัตโนมัติ
REDIS_URL=redis://:CHANGE_ME_strong_password@redis:6379/0

# ============================================
# MinIO (Object Storage) (🔒 แก้ password)
# ============================================
MINIO_USER=timsumadmin
MINIO_PASS=CHANGE_ME_min_8_chars

# ============================================
# Google SSO (Optional — leave blank to disable)
# ============================================
# ถ้าไม่ใช้ Google SSO ไม่ต้องใส่ (ระบบจะ disable อัตโนมัติ)
# GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# Default Users (auto-created on startup)
# ============================================
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@timsumv3.local
SUPERADMIN_PASS=TimSum@SuperAdmin2026

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@timsumv3.local
ADMIN_PASS=TimSum@Admin2026

# ============================================
# Application Settings
# ============================================
# CORS — comma-separated origins (e.g. https://timsum.yourorg.com)
# ⚠️ ถ้า deploy ขึ้น server จริง ต้องเปลี่ยนให้ตรงกับ domain ที่ใช้
ALLOWED_ORIGINS=http://localhost:3000

# Max upload file size in MB
MAX_UPLOAD_MB=500
